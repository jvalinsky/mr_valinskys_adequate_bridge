FROM golang:1.25-bookworm AS test

RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc libc6-dev sqlite3 && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /src

# Download dependencies first for layer caching.
# reference/go-ssb-room is needed because go.mod points to it via replace directive.
COPY go.mod go.sum ./
COPY reference/go-ssb-room reference/go-ssb-room
RUN go mod download

COPY . .
RUN CGO_ENABLED=1 go test -count=1 -timeout 120s ./...
